APP_NAME=SIGESC-SITE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Legacy weekly AI blog (disabled automatically when AI Content Engine is on)
AI_BLOG_ENABLED=false
AI_BLOG_GENERATE_IMAGES=false
AI_BLOG_POSTS_PER_TOPIC=1
AI_BLOG_AUTHOR_NAME="Equipa SIGESC"
AI_BLOG_AUTHOR_AVATAR="/img/sigesc capa.png"
AI_BLOG_AUTHOR_ROLE="Análise & Conteúdo"

# AI Content Engine (multi-agent)
AI_CONTENT_ENGINE_ENABLED=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_REVIEW_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=180
OPENAI_IMAGE_MODEL=dall-e-3
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=8
GEMINI_API_KEY=
GEMINI_ENABLED=false
AI_CONTENT_TOPICS_PER_DAY=3
AI_CONTENT_REQUIRE_FACT_CHECK=true
AI_CONTENT_AUTO_PUBLISH=false
AI_CONTENT_SCHEDULE_DELAY_HOURS=6
AI_CONTENT_MIN_CONFIDENCE=0.72
AI_CONTENT_SYNC_TO_POSTS=true
AI_CONTENT_DISK=public
AI_CONTENT_ADMIN_EMAILS=
AI_CONTENT_AUTHOR_NAME="Equipa Editorial SIGESC"
AI_CONTENT_AUTHOR_AVATAR="/img/sigesc capa.png"
AI_CONTENT_AUTHOR_ROLE="AI Content Engine"

# Queues: use redis + Laravel Horizon in production
# QUEUE_CONNECTION=redis
# REDIS_CLIENT=phpredis

# Optional Inertia SSR Node process (php artisan inertia:start-ssr)
INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://127.0.0.1:13714
